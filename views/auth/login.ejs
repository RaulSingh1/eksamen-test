<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Logg inn</title>
  <link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<header class="header">
  <h1>WCAG Vurderingssystem</h1>
  <nav>
    <a href="/">Forside</a>
    <a href="/websites">Nettsider</a>
    <a href="/reviews">Vurderinger</a>
    <a href="/auth/register">Registrer</a>
  </nav>
</header>

<section class="auth-container">
  <div class="auth-card">
    <h2>Logg inn</h2>

    <% if (error) { %>
      <div class="error-box"><%= error %></div>
    <% } %>

    <form method="POST" action="/auth/login">
      <label>Email</label>
      <input type="email" name="email" required>

      <label>Passord</label>
      <input type="password" name="password" required>

      <button type="submit" class="btn-primary full">Logg inn</button>
    </form>

    <p class="auth-link">
      Har du ikke konto?
      <a href="/auth/register">Registrer deg her</a>
    </p>
  </div>
</section>

</body>
</html>