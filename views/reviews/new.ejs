<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="header">
    <h1><a href="/">WCAG Vurderingssystem</a></h1>
  </header>

  <main class="container">
    <h2>Legg til nettside</h2>

    <form action="/websites" method="POST">
      <label>Navn:</label><br/>
      <input type="text" name="name" required><br/><br/>

      <label>URL:</label><br/>
      <input type="url" name="url" required><br/><br/>

      <label>Beskrivelse:</label><br/>
      <textarea name="description" rows="3"></textarea><br/><br/>

      <button type="submit">Lagre</button>
    </form>

    <br/>
    <a href="/websites">Tilbake</a>
  </main>
</body>
</html>