<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title><%= title %></title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="header">
    <h1><a href="/">WCAG Vurderingssystem</a></h1>
    <nav>
      <a href="/websites/new">Legg til nettside</a>
    </nav>
  </header>

  <main class="container">
    <h2>Nettsider</h2>

    <% if (websites.length === 0) { %>
      <p>Ingen nettsider lagt til enda.</p>
    <% } %>

    <ul>
      <% websites.forEach(site => { %>
        <li>
          <strong><%= site.name %></strong> –
          <a href="<%= site.url %>" target="_blank">Besøk</a>
          <br/>
          <small><%= site.description || "Ingen beskrivelse" %></small>
        </li>
        <br/>
      <% }) %>
    </ul>
  </main>
</body>
</html>