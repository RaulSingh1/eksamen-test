<!DOCTYPE html>
<html lang="no">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title || "Nettsider" %></title>
  <link rel="stylesheet" href="/css/styles.css" />
</head>
<body>
  <header class="header">
    <h1><a href="/">WCAG Vurderingssystem</a></h1>
    <nav>
      <a href="/">Forside</a>
      <a href="/websites">Nettsider</a>
      <a href="/reviews">Vurderinger</a>
      <a href="/faq">FAQ</a>
      <% if (!user) { %>
        <a href="/auth/login">Logg inn</a>
      <% } else { %>
        <span class="welcome">Hei, <%= user.username %></span>
        <% if (user.role === "admin") { %>
          <a href="/admin/reports">Admin</a>
        <% } %>
        <a href="/auth/logout">Logg ut</a>
      <% } %>
    </nav>
  </header>

  <main class="website-list-section">
    <h2>Liste over nettsider</h2>
    <p>Her vises kun en enkel oversikt over nettsidene. Gå til "Vurderinger" for å se og lage vurderinger.</p>

    <% if (!websites || websites.length === 0) { %>
      <p>Ingen nettsider lagt til enda.</p>
    <% } else { %>
      <ul class="website-list">
        <% websites.forEach(site => { %>
          <li class="website-list-item">
            <a href="<%= site.url %>" target="_blank" rel="noopener noreferrer">
              <strong><%= site.name %></strong>
            </a>
            <p><%= site.description || "Ingen beskrivelse." %></p>
            <small>Lagt ut av: <%= site.user?.username || "Ukjent bruker" %></small>
          </li>
        <% }) %>
      </ul>
    <% } %>
  </main>
</body>
</html>
